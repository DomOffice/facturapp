# FacturApp – Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs

# ─── BASE DE DONNÉES ──────────────────────────────────────────────
# PostgreSQL – Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://facturapp:motdepasse@localhost:5432/facturapp_db"

# ─── AUTHENTIFICATION ─────────────────────────────────────────────
# Générer avec : openssl rand -base64 32
NEXTAUTH_SECRET="remplacer_par_une_cle_secrete_de_32_caracteres"
NEXTAUTH_URL="http://localhost:3000"

# ─── APPLICATION ──────────────────────────────────────────────────
NODE_ENV="development"

# Dossier de stockage des factures fournisseurs importées
# Windows production exemple :
UPLOAD_DIR=C:/serveur/Factures_achats